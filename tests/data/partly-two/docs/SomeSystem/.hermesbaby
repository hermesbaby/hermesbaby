
#
# Document
#
CONFIG_DOC__TITLE="System Definition of SomeSystem"
CONFIG_DOC__AUTHOR="The Default Author"
CONFIG_DOC__YEAR=1976
CONFIG_DOC__PROJECT="The Default Project"
CONFIG_DOC__LANGUAGE="en"
CONFIG_DOC_LANGUAGE_ENGLISH=y
# CONFIG_DOC_LANGUAGE_GERMAN is not set
CONFIG_DOC__CONFIDENTIALITY_LEVEL_LABEL="Confidentiality level"
CONFIG_DOC__CONFIDENTIALITY_LEVEL="Public"
CONFIG_DOC__CONFIDENTIALITY_PUBLIC=y
# CONFIG_DOC__CONFIDENTIALITY_INTERNAL is not set
# CONFIG_DOC__CONFIDENTIALITY_CONFIDENTIAL is not set
# CONFIG_DOC__CONFIDENTIALITY_STRICTLY_CONFIDENTIAL is not set
# end of Document

#
# CM
#
CONFIG_CM__TICKET_KEY="PRJ"
# end of CM

#
# SCM
#
CONFIG_SCM__HOST="host.some.com:4711"
CONFIG_SCM__OWNER_KIND="projects"
CONFIG_SCM__PROJECT=y
# CONFIG_SCM__USER is not set
CONFIG_SCM__OWNER="SomeOwner"
CONFIG_SCM__REPO="SomeRepository"
CONFIG_SCM__REPO__URL_GIT_CLIENT="https://github.com/hermesbaby/some-doc.git"
# end of SCM

#
# Build
#
CONFIG_BUILD__DIRS__SOURCE="."
CONFIG_BUILD__DIRS__CONFIG="."
CONFIG_BUILD__DIR_PARTLY="."
CONFIG_BUILD__DIRS__BUILD="out"
CONFIG_BUILD__PORTS__HTML__LIVE=0
CONFIG_BUILD__PORTS__PDF__LIVE=0
# end of Build

#
# Link Patterns
#
CONFIG_LINK_PATTERNS__JIRA="https://github.com/hermesbaby/hermesbaby/issues/%s"
CONFIG_LINK_PATTERNS__ISSUE="https://github.com/hermesbaby/hermesbaby/issues/%s"
CONFIG_LINK_PATTERNS__REPO="https://github.com/%s.git"
CONFIG_LINK_PATTERNS__JOB="https://github.com/%s/actions/"
CONFIG_LINK_PATTERNS__USER="https://github.com/%s"
# end of Link Patterns

#
# Styling
#
CONFIG_STYLING__COLOR_PRIMARY=""
CONFIG_STYLING__COLOR_ACCENT=""
CONFIG_STYLING__GLOBALTOC_DEPTH=3
# end of Styling

#
# Publish
#
# CONFIG_PUBLISH__CREATE_AND_EMBED_PDF is not set
# CONFIG_PUBLISH__TARBALL is not set
CONFIG_PUBLISH__HOST="docs.some-host.com"
CONFIG_PUBLISH__USER=""
CONFIG_PUBLISH__REPO=""
CONFIG_PUBLISH__SSH_PATH=".ci/.ssh"
CONFIG_PUBLISH__CROSS_REFERENCES__USER="intersphinx"
CONFIG_PUBLISH__CROSS_REFERENCES__PASSWORD="xnihpsretni"
# end of Publish
